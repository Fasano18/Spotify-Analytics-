# Spotify API Credentials
# Obtenha em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=seu_client_id_aqui
SPOTIFY_CLIENT_SECRET=seu_client_secret_aqui

# Redirect URI - deve corresponder ao configurado no Spotify Dashboard
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/auth/callback

# Server Configuration
HOST=0.0.0.0
PORT=8888
DEBUG=false

# API Configuration
REQUEST_TIMEOUT_SECONDS=10.0
MAX_RETRIES=3

# Frontend URL (opcional, para CORS em produção)
# FRONTEND_BASE_URL=http://localhost:3000
